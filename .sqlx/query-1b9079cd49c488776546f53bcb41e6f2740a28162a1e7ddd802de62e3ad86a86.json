  "query": "SELECT s.token,\n                      s.user_id,\n                      s.csrf_token,\n                      u.role as `role?: String`,\n                      u.preferred_language as `preferred_language?: String`,\n                      s.last_activity\n               FROM sessions s\n               LEFT JOIN users u ON s.user_id = u.id AND u.deleted_at IS NULL\n               WHERE s.token = ?\n                 AND s.deleted_at IS NULL",
