  "query": "SELECT s.token,\n                      s.user_id,\n                      u.role as `role: String`,\n                      s.last_activity,\n                      u.preferred_language as `preferred_language?: String`\n               FROM sessions s\n               JOIN users u ON s.user_id = u.id\n               WHERE s.token = ?\n                 AND s.deleted_at IS NULL\n                 AND u.deleted_at IS NULL",
